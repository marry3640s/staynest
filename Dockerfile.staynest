FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV STAYNEST_DEV_SMS=1

WORKDIR /app

COPY requirements.staynest.txt README.md ./
RUN pip install --no-cache-dir -r requirements.staynest.txt
COPY src ./src
COPY staynest ./staynest

EXPOSE 4174

CMD ["python", "-m", "src.staynest_auth_server", "--host", "0.0.0.0", "--port", "4174"]
